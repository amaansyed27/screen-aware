{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Screen-Aware",
  "version": "0.1.0",
  "identifier": "io.screenaware.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Screen-Aware",
        "width": 460,
        "height": 590,
        "minWidth": 380,
        "minHeight": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "backgroundColor": "#f4f0e8"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8787 ws://127.0.0.1:8787; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
