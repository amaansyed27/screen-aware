# Backend auth. Set one of these; VIDEO_DB_API_KEY is preferred by the Python SDK.
VIDEO_DB_API_KEY=replace-with-your-videodb-key
# VIDEODB_API_KEY=replace-with-your-videodb-key

VIDEODB_COLLECTION_ID=default
VIDEODB_API_URL=https://api.videodb.io

SCREEN_AWARE_DATA_DIR=.screen-aware
# Optional for MCP clients launched outside this folder. Use an absolute path in client configs.
# SCREEN_AWARE_ENV_FILE=C:\Users\Amaan\Downloads\screen-aware\.env
SCREEN_AWARE_API_HOST=127.0.0.1
SCREEN_AWARE_API_PORT=8787
SCREEN_AWARE_FRONTEND_ORIGIN=http://127.0.0.1:5173

# Optional public webhook endpoint, for example from ngrok:
# https://your-tunnel.ngrok-free.app/webhooks/videodb
SCREEN_AWARE_PUBLIC_WEBHOOK_URL=

SCREEN_AWARE_CLIENT_TOKEN_TTL_SECONDS=3600
SCREEN_AWARE_VISUAL_MODEL=basic
SCREEN_AWARE_VISUAL_BATCH_SECONDS=3
SCREEN_AWARE_VISUAL_FRAME_COUNT=3
SCREEN_AWARE_AUDIO_BATCH_WORDS=50

# Optional live overlay replies.
# OpenRouter is the default provider. Set either SCREEN_AWARE_LIVE_API_KEY or OPENROUTER_API_KEY.
# Do not put this key in MCP client configs.
SCREEN_AWARE_LIVE_PROVIDER=openrouter
SCREEN_AWARE_LIVE_API_KEY=
SCREEN_AWARE_LIVE_BASE_URL=https://openrouter.ai/api/v1
SCREEN_AWARE_LIVE_MODEL=google/gemini-3-flash-preview
SCREEN_AWARE_LIVE_FALLBACK_MODELS=google/gemini-3.1-flash-lite,google/gemini-3.1-flash-lite-preview
SCREEN_AWARE_LIVE_THINKING_LEVEL=low
SCREEN_AWARE_LIVE_TIMEOUT_SECONDS=20
SCREEN_AWARE_LIVE_CONTEXT_TIMEOUT_SECONDS=4
SCREEN_AWARE_LIVE_MAX_CONTEXT_EVENTS=14

# Direct Gemini API alternative:
# SCREEN_AWARE_LIVE_PROVIDER=gemini
# SCREEN_AWARE_LIVE_API_KEY=replace-with-gemini-key
# SCREEN_AWARE_LIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# SCREEN_AWARE_LIVE_MODEL=gemini-3-flash-preview
# SCREEN_AWARE_LIVE_FALLBACK_MODELS=gemini-3.1-flash-lite-preview
